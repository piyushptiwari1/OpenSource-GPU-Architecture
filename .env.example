# OpenSource-GPU-Architecture — environment variable schema
#
# Copy to `.env` (gitignored) and fill in real values for local use.
# CI uses GitHub Actions Secrets with the same names.
#
# This file is committed: it MUST contain only placeholder names + comments,
# never real secrets.

# ---------------------------------------------------------------------------
# Required for CI
# ---------------------------------------------------------------------------

# Codecov upload token. Obtain from https://app.codecov.io/gh/<owner>/<repo>.
CODECOV_TOKEN=

# PyPI publishing token (scoped to this project or the user's default).
# Format: pypi-<base64 string>.
PYPI_API_TOKEN=

# HuggingFace Hub token (model card / demo publishing).
# Format: hf_<32+ chars>.
HF_TOKEN=

# ---------------------------------------------------------------------------
# Provided automatically by GitHub Actions; do NOT set locally
# ---------------------------------------------------------------------------
# GITHUB_TOKEN

# ---------------------------------------------------------------------------
# Build / runtime knobs (safe defaults; override locally)
# ---------------------------------------------------------------------------

# Functional simulator backend: iverilog | verilator
SIM=iverilog

# Generate FST waveforms (1 = on, 0 = off).
WAVES=1

# Per-test simulation timeout (cocotb timeout_unit = ns).
SIM_TIMEOUT_NS=1000000

# DRAM model: simple | dramsim3 | ramulator2
MEM_MODEL=simple

# Path to selected DRAM config YAML (required when MEM_MODEL != simple).
MEM_CONFIG=

# Cocotb log level: DEBUG | INFO | WARNING | ERROR
COCOTB_LOG_LEVEL=INFO

# Deterministic RNG seed for cocotb tests.
RANDOM_SEED=42

# Optional pytest -k expression to filter tests.
TEST_FILTER=

# Enable line+toggle+functional coverage (1 = on).
COVERAGE=0

# Enable lockstep DiffTest (cocotb vs C++ ref). Requires sim/cppref build.
DIFFTEST=0

# ---------------------------------------------------------------------------
# Open ASIC flow (OpenLane2 + sky130A) — set when running flow/openlane2/
# ---------------------------------------------------------------------------
PDK=sky130A
PDK_ROOT=
STD_CELL_LIBRARY=sky130_fd_sc_hd

# ---------------------------------------------------------------------------
# Open FPGA flow — board selector
# ---------------------------------------------------------------------------
# Supported: ulx3s | tang-nano-20k | icebreaker | arty-a7 | de10-lite
BOARD=ulx3s

# Output bitstream path (default: build/fpga/<board>/top.bit).
BITSTREAM_OUT=

# ---------------------------------------------------------------------------
# Tinygrad / ML demo runtime
# ---------------------------------------------------------------------------
# Where to execute kernels: sim | fpga
OPENGPU_RUNTIME=sim

# Serial device for FPGA runtime (when OPENGPU_RUNTIME=fpga).
OPENGPU_FPGA_DEV=/dev/ttyUSB0

# ---------------------------------------------------------------------------
# Optional / deferred (uncomment + populate only when needed)
# ---------------------------------------------------------------------------

# DISCORD_WEBHOOK_URL=          # CI failure pings (declined for now)
# DOCKERHUB_USERNAME=           # Docker Hub mirror of toolchain image
# DOCKERHUB_TOKEN=
# CHIPFOUNDRY_API_TOKEN=        # Tape-out submission (chipfoundry.io)
# IHP_PDK_TOKEN=                # IHP Open PDK shuttles
# WANDB_API_KEY=                # Benchmark dashboard alternative

# ---------------------------------------------------------------------------
# Commercial EDA — self-hosted runners only, never public CI
# ---------------------------------------------------------------------------
# SNPS_LM_LICENSE_FILE=
# CDS_LIC_FILE=
# MENTOR_LICENSE_FILE=
# XILINXD_LICENSE_FILE=
