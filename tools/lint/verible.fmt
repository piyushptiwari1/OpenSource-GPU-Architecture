# Verible formatter style for OpenSource-GPU-Architecture.
# Applied via:
#   verible-verilog-format --flagfile=tools/lint/verible.fmt --inplace <file>

--column_limit=100
--indentation_spaces=4
--wrap_spaces=4
--line_break_penalty=2
--over_column_limit_penalty=100

--assignment_statement_alignment=align
--case_items_alignment=align
--class_member_variable_alignment=align
--compact_indexing_and_selections=true
--enum_assignment_statement_alignment=align
--formal_parameters_alignment=align
--module_net_variable_alignment=align
--named_parameter_alignment=align
--named_port_alignment=align
--port_declarations_alignment=align
--struct_union_members_alignment=align

--port_declarations_indentation=indent
--port_declarations_right_align_packed_dimensions=true
--port_declarations_right_align_unpacked_dimensions=true

--try_wrap_long_lines=true
--wrap_end_else_clauses=false
