# Pinned tool versions for reproducible builds.
# Single source of truth for both local dev (.devcontainer) and CI
# (containers/toolchain). Update via PR; CI image is rebuilt on change.
#
# Format: shell-sourceable KEY=VALUE. No spaces around `=`. Quote values
# only when they contain special characters.

# --- OSS CAD Suite (Yosys, Verilator, iverilog, nextpnr, gtkwave, ...) ---
# Release tag from https://github.com/YosysHQ/oss-cad-suite-build/releases
OSS_CAD_SUITE_DATE=2025-01-01
OSS_CAD_SUITE_TAG=2025-01-01
OSS_CAD_SUITE_ARCH=linux-x64
# SHA256 of oss-cad-suite-${OSS_CAD_SUITE_ARCH}-${OSS_CAD_SUITE_DATE//-/}.tgz.
# Leave empty to skip verification (NOT recommended). Set in CI/dev image
# build to enforce supply-chain integrity.
OSS_CAD_SUITE_SHA256=

# --- Verible (formatter + lint) ---
# https://github.com/chipsalliance/verible/releases
VERIBLE_VERSION=v0.0-4053-g89d4d98a

# --- sv2v (SystemVerilog -> Verilog2005 transpiler) ---
# https://github.com/zachjs/sv2v/releases
# Required because OSS CAD Suite does not bundle sv2v.
SV2V_VERSION=v0.0.13

# --- Python toolchain (pyslang, ruff, mypy, cocotb, pytest) ---
PYTHON_VERSION=3.12

# --- OpenROAD-flow-scripts / OpenLane2 (used by flow-asic.yml) ---
# Pulled lazily (not in base toolchain image) to keep image small.
OPENLANE2_VERSION=2.2.9

# --- Container image coordinates ---
TOOLCHAIN_IMAGE=ghcr.io/piyushptiwari1/opengpu-toolchain
