{
    "name": "OpenGPU dev container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "TOOLCHAIN_IMAGE": "ghcr.io/piyushptiwari1/opengpu-toolchain:latest"
        }
    },
    "remoteUser": "dev",
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "containerEnv": {
        "PYTHONDONTWRITEBYTECODE": "1",
        "PIP_DISABLE_PIP_VERSION_CHECK": "1"
    },
    "mounts": [
        "source=opengpu-bash-history,target=/home/dev/.bash_history_dir,type=volume"
    ],
    "postCreateCommand": "pip install -e '.[dev]' && pre-commit install --install-hooks",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "chipsalliance.verible",
                "mshr-h.veriloghdl",
                "eamodio.gitlens",
                "tamasfe.even-better-toml",
                "redhat.vscode-yaml",
                "github.vscode-github-actions",
                "editorconfig.editorconfig"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/venv/bin/python",
                "python.terminal.activateEnvironment": false,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "files.eol": "\n"
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    }
}
